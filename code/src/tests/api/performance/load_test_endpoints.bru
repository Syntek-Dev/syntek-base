meta {
  name: Load Test — Core Endpoints (Response Time)
  type: http
  seq: 1
}

get {
  url: {{api_url}}/health
  auth: none
}

tests {
  test("Health endpoint returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  // Baseline: health check must respond within 100ms even under load.
  test("Health response time < 100ms", function() {
    expect(res.getResponseTime()).to.be.below(100);
  });
}
