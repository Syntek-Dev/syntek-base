meta {
  name: Login (Invalid Password)
  type: http
  seq: 2
}

post {
  url: {{api_url}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "test@example.com",
    "password": "this-is-wrong"
  }
}

tests {
  test("Status is 401 Unauthorized", function() {
    expect(res.getStatus()).to.equal(401);
  });

  test("Response does not contain access_token", function() {
    expect(res.body).to.not.have.property("access_token");
  });

  test("Response contains error message", function() {
    expect(res.body).to.have.property("error");
  });

  test("Content-Type is JSON", function() {
    expect(res.getHeader("content-type")).to.include("application/json");
  });

  test("Response time < 500ms", function() {
    expect(res.getResponseTime()).to.be.below(500);
  });
}
