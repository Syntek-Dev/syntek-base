# Development environment variables
# Copy to .env.dev and fill in the required values before running:
#   docker compose -f code/src/docker/docker-compose.dev.yml --env-file code/src/docker/.env.dev up

# --- PostgreSQL ---
# Optional — defaults to "syntek" if not set
POSTGRES_USER=syntek
# Required
POSTGRES_PASSWORD=change_me

# --- Django ---
# Required — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change_me
# Optional — defaults to true in dev
DEBUG=true
# Required — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me
# Optional — defaults shown; EMAIL_HOST/PORT match the maildev container
EMAIL_HOST=maildev
EMAIL_PORT=1025
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=noreply@projectname.com
