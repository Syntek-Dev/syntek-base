# Production environment variables
# Set these via managed secrets (e.g. GitHub Actions environment secrets, Vault).
# Never store a populated copy of this file on disk or in version control.
#
# Deploy: docker compose -f docker-compose.prod.yml --env-file .env.prod pull && \
#         docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# --- Image ---
# Required — the exact GHCR tag to deploy (e.g. a Git SHA or semver tag)
IMAGE_TAG=

# --- Database ---
# Required — full DSN including credentials
# Example: postgresql://user:password@db-host:5432/syntek_website_prod
DATABASE_URL=

# --- Cache ---
# Required — Valkey/Redis DSN
# Example: redis://cache-host:6379/0
REDIS_URL=

# --- Django ---
# Required — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
# Required — comma-separated hostnames (no scheme)
# Example: syntekstudio.com,www.syntekstudio.com
ALLOWED_HOSTS=
# Required — comma-separated full origins (with scheme)
# Example: https://syntekstudio.com,https://www.syntekstudio.com
CORS_ALLOWED_ORIGINS=

# --- Frontend ---
# Required — full URL to the GraphQL endpoint as seen by the browser
# Example: https://syntekstudio.com/graphql/
NEXT_PUBLIC_GRAPHQL_URL=

# --- Gunicorn tuning (optional — override defaults) ---
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=30
# GUNICORN_MAX_REQUESTS=1000
