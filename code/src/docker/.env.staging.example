# Staging environment variables
# Set these on the staging server (e.g. via CI secrets or a server-side .env.staging).
# Never commit a populated copy of this file.
#
# Deploy: docker compose -f docker-compose.staging.yml --env-file .env.staging up -d

# --- Image ---
# Required — the GHCR tag to pull (e.g. the Git SHA or "staging")
IMAGE_TAG=staging

# --- Database ---
# Required — full DSN including credentials
# Example: postgresql://user:password@db-host:5432/syntek_website_staging
DATABASE_URL=

# --- Cache ---
# Required — Valkey/Redis DSN
# Example: redis://cache-host:6379/0
REDIS_URL=

# --- Django ---
# Required — generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
# Required — comma-separated hostnames (no scheme)
# Example: staging.syntekstudio.com
ALLOWED_HOSTS=
# Required — comma-separated full origins (with scheme)
# Example: https://staging.syntekstudio.com
CORS_ALLOWED_ORIGINS=

# --- Frontend ---
# Required — full URL to the GraphQL endpoint as seen by the browser
# Example: https://staging.syntekstudio.com/graphql/
NEXT_PUBLIC_GRAPHQL_URL=

# --- Gunicorn tuning (optional — override defaults) ---
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=30
# GUNICORN_MAX_REQUESTS=1000
