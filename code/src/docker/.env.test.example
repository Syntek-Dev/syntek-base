# Test environment variables
# All variables have safe defaults for local test runs.
# Copy to .env.test only if you need to override the defaults:
#   docker compose -f code/src/docker/docker-compose.test.yml --env-file code/src/docker/.env.test up --abort-on-container-exit

# --- PostgreSQL ---
POSTGRES_USER=syntek
POSTGRES_PASSWORD=test_password_change_me

# --- Django ---
# Never use this key outside of local testing
SECRET_KEY=test-secret-key-not-for-production
DEBUG=false
# Optional — test settings fall back to a zero-byte test key if omitted
# ENCRYPTION_KEY=

# --- Bruno API tests ---
# Password for the test user account used by api.sh / test-api.yml
# Set in shell before running api.sh:  BRUNO_VAR_test_password=secret ./code/src/scripts/tests/api.sh
# In CI this is injected via the API_TEST_PASSWORD GitHub secret.
# BRUNO_VAR_test_password=
