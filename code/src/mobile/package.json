{
  "name": "@syntek/mobile",
  "version": "1.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start",
    "storybook:generate": "sb-rn-get-stories --config-path .storybook"
  },
  "dependencies": {
    "@apollo/client": "^3.13.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@syntek/shared": "workspace:*",
    "expo": "~54.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "graphql": "^16.10.0",
    "nativewind": "4.2.3",
    "react": "19.2.0",
    "react-native": "~0.85.0",
    "react-native-css-interop": "0.2.3",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "~4.14.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/client-preset": "^5.0.0",
    "@testing-library/react-native": "^12.7.0",
    "@types/react": "^19.1.0",
    "babel-preset-expo": "~12.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "jest-junit": "^16.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.0",
    "@storybook/addon-ondevice-actions": "^8.0.0",
    "@storybook/addon-ondevice-backgrounds": "^8.0.0",
    "@storybook/addon-ondevice-controls": "^8.0.0",
    "@storybook/addon-ondevice-notes": "^8.0.0",
    "@storybook/react-native": "^8.3.0",
    "storybook": "^8.6.0"
  }
}
